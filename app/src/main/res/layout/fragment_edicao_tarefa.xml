<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Tarefa"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etEditTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/titulo"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etEditDescricao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/descricao"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:gravity="top"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSalvarEdicao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/salvar"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnFavoritarTarefa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Favoritar"
        android:backgroundTint="#FFEB3B"
        android:textColor="#000000"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnCompartilharTarefa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Compartilhar"
        android:backgroundTint="#2196F3"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnExcluirTarefa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/excluir"
        android:backgroundTint="#F44336"
        android:textColor="@android:color/white"/>

</LinearLayout>
