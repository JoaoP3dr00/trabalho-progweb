<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#E3F2FD">

    <TextView
        android:id="@+id/tvTituloAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Painel Administrativo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnGerenciarUsuarios"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Usuários"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnRelatorios"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Relatórios do Sistema"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSairAdmin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Sair"
        android:backgroundTint="#F44336"/>

</LinearLayout>
